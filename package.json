{
  "name": "ShadowWallet",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "adb:reverse": "adb reverse tcp:8081 tcp:8081",
    "adb:install": "cd android && gradlew.bat app:installDebug -PreactNativeDevServerPort=8081",
    "adb:launch": "adb shell am start -n com.shadowwallet/.MainActivity",
    "adb:restart": "adb shell am force-stop com.shadowwallet && adb shell am start -n com.shadowwallet/.MainActivity",
    "dev": "bash dev.sh",
    "deploy": "npm run adb:install && npm run adb:reverse && npm run adb:launch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "jest"
  },
  "dependencies": {
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@op-engineering/op-sqlite": "^15.2.11",
    "@react-native/new-app-screen": "0.85.1",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.11",
    "axios": "^1.15.0",
    "fflate": "^0.8.2",
    "i18next": "^26.0.5",
    "jsonpath-plus": "^10.4.0",
    "lottie-react-native": "^7.3.6",
    "react": "19.2.3",
    "react-i18next": "^17.0.4",
    "react-native": "0.85.1",
    "react-native-biometrics": "^3.0.1",
    "react-native-config": "^1.6.1",
    "react-native-get-random-values": "^2.0.0",
    "react-native-keychain": "^10.0.0",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "react-native-svg": "^15.15.4",
    "react-native-vision-camera": "^4.7.3",
    "react-native-worklets-core": "^1.6.3",
    "uuid": "^13.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.85.1",
    "@react-native/eslint-config": "0.85.1",
    "@react-native/jest-preset": "0.85.1",
    "@react-native/metro-config": "0.85.1",
    "@react-native/typescript-config": "0.85.1",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "@types/uuid": "^11.0.0",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  },
  "op-sqlite": {
    "sqlcipher": true
  }
}
